SECRET_KEY=change-this-to-a-long-random-string
DATABASE_URL=sqlite:///inoutvehicle.db

# Configuração de E-mail (SMTP)
# Para Gmail: use uma "Senha de App" (https://myaccount.google.com/apppasswords)
# Para Outlook/Office365: MAIL_SERVER=smtp.office365.com, MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_DEFAULT_SENDER=InOut Veículos <seu-email@gmail.com>
